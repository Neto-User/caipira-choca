generator client {
  provider = "prisma-client"
  output   = "../../generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

model User {
  id          Int       @id @default(autoincrement())
  email       String    @unique
  password    String    // hash da senha
  name        String
  phone       String    @unique
  address     String?   // onde mora
  role        Role      @default(CUSTOMER)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  orders      Order[]
  notifications Notification[]
}

model Order {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  
  productId   Int
  product     Product   @relation(fields: [productId], references: [id])
  
  quantity    Int
  pickupDate  DateTime?
  status      OrderStatus @default(PENDING)
  whatsappSent Boolean  @default(false)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          Int       @id @default(autoincrement())
  name        String    // "Pintinho Caipira Embrapa 051", "Frango Caipira Pesadão"
  type        ProductType // PINTINHO ou FRANGO
  breed       String    // raça específica
  imageUrl    String?   // URL da imagem
  status      ProductStatus @default(EMPTY) // VAZIO, CHOCANDO, ESTOQUE
  description String?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  orders      Order[]
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  
  title     String   // "Novo pedido de João!"
  message   String   // "Quer 50 pintinhos dia 15/03"
  read      Boolean  @default(false)
  
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  CUSTOMER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  READY
  CANCELED
}

enum ProductType {
  PINTINHO
  FRANGO
}

enum ProductStatus {
  EMPTY      // sem estoque
  CHOCANDO   // chocando (mostra data prevista)
  ESTOQUE    // disponível agora
}